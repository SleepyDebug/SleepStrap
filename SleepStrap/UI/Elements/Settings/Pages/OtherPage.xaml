<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.OtherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800" Title="Other" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18" CornerRadius="14" BorderThickness="1" BorderBrush="#668B5CF6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#442D1760" Offset="0" />
                    <GradientStop Color="#662D1B69" Offset="0.55" />
                    <GradientStop Color="#33211A3A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Other" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="SleepStrap 6.7" Margin="0,4,0,0" FontSize="13" Foreground="#C4B5FD" />
                </StackPanel>
                <ui:SymbolIcon Grid.Column="1" Symbol="Info24" FontSize="34" Foreground="#A78BFA" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="18" CornerRadius="12"
                Background="{DynamicResource SleepStrapGlassSurfaceBrush}"
                BorderBrush="{DynamicResource SleepStrapGlassBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Discord" FontSize="17" FontWeight="Medium" />
                    <TextBlock Text="Updates, support, and the SleepStrap community." Margin="0,4,0,0"
                               FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Anchor Grid.Column="1" Content="Join Discord" Icon="Chat24"
                           NavigateUri="https://discord.gg/W3CMjx8C7s" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="18" CornerRadius="12"
                Background="{DynamicResource SleepStrapGlassSurfaceBrush}"
                BorderBrush="{DynamicResource SleepStrapGlassBorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Terms of Use &amp; Risk Notice" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12.5" LineHeight="19"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="1. Unofficial software." />
                    <LineBreak />
                    <Run Text="SleepStrap is an independent, community-made Roblox launcher and modification utility. It is not made, sponsored, endorsed, approved, or supported by Roblox Corporation. Roblox and related names, logos, and assets are trademarks or property of their respective owners." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="2. Fork and attribution." />
                    <LineBreak />
                    <Run Text="SleepStrap is a fork derived from SleepStrap and SleepStrap and also uses code, libraries, concepts, and assets from the wider open-source software community. SleepStrap, SleepStrap, their contributors, and included third-party projects remain separate projects owned by their respective authors. Their retained license notices apply to the portions of software they cover. SleepStrap does not claim ownership of Roblox, SleepStrap, SleepStrap, or third-party intellectual property." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="3. Account enforcement and bans." />
                    <LineBreak />
                    <Run Text="You use SleepStrap entirely at your own risk. SleepStrap changes local settings and may replace local Roblox assets, apply FastFlags, alter graphics behavior, change display settings, or interact with files used by Roblox. Roblox may change its rules, detection systems, client, or enforcement practices at any time. We do not promise that any feature is permitted by Roblox or safe from detection. We are not responsible for warnings, suspensions, account bans, hardware bans, lost access, deleted progress, lost purchases, moderation actions, or any other penalty connected directly or indirectly to installing, launching, configuring, or using SleepStrap." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="4. Your responsibility." />
                    <LineBreak />
                    <Run Text="You are responsible for reviewing and following the Roblox Terms of Use, Community Standards, game rules, platform rules, and all laws that apply to you. You are responsible for deciding whether each modification, visual option, FastFlag, texture, font, skybox, display stretch, or other feature is appropriate for your account and computer. If you are not willing to accept the possibility of account enforcement or technical problems, do not use SleepStrap." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="5. No warranty." />
                    <LineBreak />
                    <Run Text="SleepStrap is provided as-is and as-available, without warranties or guarantees of any kind. We do not guarantee that it will always work, remain compatible with Roblox or Windows, improve performance, preserve files, avoid crashes, prevent data loss, or be free of bugs, security issues, interruptions, or false detections. Features can stop working after Roblox, Windows, graphics-driver, browser, or third-party service updates." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="6. Device and data risk." />
                    <LineBreak />
                    <Run Text="Some options modify files, configuration values, graphics settings, local caches, fonts, textures, display resolution, or other device state. Backups and restore features are provided for convenience but are not guaranteed. You are responsible for your own backups and for confirming settings before applying them. We are not responsible for corrupted files, lost configurations, display problems, reduced performance, crashes, incompatibility, network use, storage use, or damage to software or hardware." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="7. Third-party content and services." />
                    <LineBreak />
                    <Run Text="SleepStrap may open or depend on Roblox, Discord, Windows components, websites, open-source packages, or other third-party software and services. Those services have their own terms and privacy practices. We do not control them and are not responsible for their availability, content, security, behavior, fees, enforcement decisions, or changes." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="8. Limitation of responsibility." />
                    <LineBreak />
                    <Run Text="To the fullest extent allowed by applicable law, the SleepStrap maintainers, distributors, contributors, SleepStrap contributors, SleepStrap contributors, and third-party component authors are not liable for direct, indirect, incidental, special, consequential, exemplary, or punitive losses arising from SleepStrap. This includes account penalties, lost data, lost revenue, lost purchases, lost opportunities, interruption, device problems, and claims by other people, even if someone was told such harm could occur." />
                    <LineBreak /><LineBreak />

                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="9. Continuing to use SleepStrap." />
                    <LineBreak />
                    <Run Text="By installing, launching, or continuing to use SleepStrap, you confirm that you understand it is unofficial, accept the risks described above, and take responsibility for your choices. If you do not agree, stop using SleepStrap and remove it. These notices may be updated in later versions as features, platform rules, and risks change." />
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</ui:UiPage>
