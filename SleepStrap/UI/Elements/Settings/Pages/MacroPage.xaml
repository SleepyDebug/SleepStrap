<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.MacroPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:SleepStrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:MacroViewModel, IsDesignTimeCreatable=False}"
      d:DesignHeight="700" d:DesignWidth="800" Title="Macro" Scrollable="True">
    <ui:UiPage.Resources>
        <DataTemplate x:Key="WeaponChoiceTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <Border Width="38" Height="38" CornerRadius="8" ClipToBounds="True" Background="#18000000">
                    <Image Source="{Binding ImageSource}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <TextBlock Text="{Binding Name}" Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CalibrationWeaponTemplate">
            <ToggleButton Width="104" Height="122" Margin="4" Padding="5"
                          IsChecked="{Binding IsMissing, Mode=TwoWay}"
                          ToolTip="Select if you do not own this item">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="82" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border CornerRadius="10" ClipToBounds="True" Background="#18000000">
                        <Image Source="{Binding ImageSource}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel Grid.Row="1" Margin="2,4,2,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="Wrap" FontSize="11" />
                        <TextBlock Text="{Binding SlotText}" TextAlignment="Center" Margin="0,2,0,0" FontSize="9"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0"
                            CornerRadius="8" Padding="5,2" Background="#E6000000">
                        <TextBlock Text="Missing" FontSize="9" Foreground="White" />
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </ToggleButton>
        </DataTemplate>
    </ui:UiPage.Resources>

    <StackPanel Margin="0,0,14,20">
        <Border Padding="18,14,18,12" CornerRadius="14" BorderThickness="0" Background="#C40A0A0C">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Macro" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ui:SymbolIcon Grid.Column="1" Symbol="Keyboard24" FontSize="34" Foreground="White" Opacity="0.72" />
                </Grid>
                <Border Grid.Row="1" Margin="0,12,0,0" Height="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#00FFFFFF" Offset="0" /><GradientStop Color="#CFFFFFFF" Offset="0.5" /><GradientStop Color="#00FFFFFF" Offset="1" /></LinearGradientBrush></Border.Background></Border>
            </Grid>
        </Border>

        <ui:CardExpander Margin="0,14,0,0" IsExpanded="False">
            <ui:CardExpander.Header>
                <TextBlock Text="Calibration" FontSize="17" FontWeight="SemiBold" />
            </ui:CardExpander.Header>
            <StackPanel>
                <TextBlock Text="Select every item you do not own." Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Text="Primary" FontSize="14" FontWeight="SemiBold" Margin="2,0,0,5" />
                <ItemsControl ItemsSource="{Binding PrimaryWeapons}" ItemTemplate="{StaticResource CalibrationWeaponTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Text="Secondary" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,5" />
                <ItemsControl ItemsSource="{Binding SecondaryWeapons}" ItemTemplate="{StaticResource CalibrationWeaponTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Text="Melee" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,5" />
                <ItemsControl ItemsSource="{Binding MeleeWeapons}" ItemTemplate="{StaticResource CalibrationWeaponTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Text="Utility" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,5" />
                <ItemsControl ItemsSource="{Binding UtilityWeapons}" ItemTemplate="{StaticResource CalibrationWeaponTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,10,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <TextBlock Text="Loadout macro" FontSize="17" FontWeight="SemiBold" />
            </ui:CardExpander.Header>
            <StackPanel>
                <Border Margin="0,0,0,14" Padding="14,11" CornerRadius="10" Background="#17FFFFFF" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Weapon layout" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LayoutName}" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Grid" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <ui:ToggleSwitch IsChecked="{Binding UseListLayout, Mode=TwoWay}" />
                        <TextBlock Text="List" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
                </Border>

                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,12">
                        <TextBlock Text="Primary" Margin="0,0,0,5" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailablePrimary}" SelectedItem="{Binding SelectedPrimary, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource WeaponChoiceTemplate}" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,12">
                        <TextBlock Text="Secondary" Margin="0,0,0,5" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailableSecondary}" SelectedItem="{Binding SelectedSecondary, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource WeaponChoiceTemplate}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,12">
                        <TextBlock Text="Melee" Margin="0,0,0,5" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailableMelee}" SelectedItem="{Binding SelectedMelee, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource WeaponChoiceTemplate}" />
                    </StackPanel>
                    <StackPanel Margin="8,0,0,12">
                        <TextBlock Text="Utility" Margin="0,0,0,5" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailableUtility}" SelectedItem="{Binding SelectedUtility, Mode=TwoWay}"
                                  ItemTemplate="{StaticResource WeaponChoiceTemplate}" />
                    </StackPanel>
                </UniformGrid>

                <Border Height="1" Background="#18FFFFFF" Margin="0,2,0,12" />
                <TextBlock Text="{Binding AutomationMasterText}" HorizontalAlignment="Center" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Border Padding="12,10" CornerRadius="10" Background="#10FFFFFF" BorderThickness="0" Margin="0,0,0,14">
                    <UniformGrid Columns="3">
                        <CheckBox Content="Quick Respawn" IsChecked="{Binding QuickRespawn, Mode=TwoWay}"
                                  ToolTip="Repeatedly presses Space" HorizontalAlignment="Center" />
                        <CheckBox Content="Auto Utility" IsChecked="{Binding AutoUtility, Mode=TwoWay}"
                                  ToolTip="Repeatedly presses G" HorizontalAlignment="Center" />
                        <CheckBox Content="Auto Inspect" IsChecked="{Binding AutoInspect, Mode=TwoWay}"
                                  ToolTip="Repeatedly presses V" HorizontalAlignment="Center" />
                    </UniformGrid>
                </Border>

                <CheckBox Content="Auto Rejoin (1hr)" IsChecked="{Binding AutoRejoinEnabled, Mode=TwoWay}"
                          HorizontalAlignment="Center" Margin="0,0,0,14" />

                <ui:Button Content="{Binding RunButtonText}" Command="{Binding RunMacroCommand}"
                           Appearance="Primary" HorizontalAlignment="Stretch" Padding="16,10" />
            </StackPanel>
        </ui:CardExpander>

    </StackPanel>
</ui:UiPage>
