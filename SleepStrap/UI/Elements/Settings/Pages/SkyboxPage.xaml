<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.SkyboxPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:SleepStrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:SkyboxViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="760" d:DesignWidth="800" Title="Skybox" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18" CornerRadius="14" BorderThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#442D1760" Offset="0" />
                    <GradientStop Color="#662D1B69" Offset="0.55" />
                    <GradientStop Color="#33211A3A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Skybox" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:SymbolIcon Grid.Column="1" Symbol="WeatherMoon24" FontSize="34" Foreground="#A78BFA" />
            </Grid>
        </Border>

        <ui:CardExpander Margin="0,14,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Skybox library" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="Choose the sky used when Roblox launches" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ui:ProgressRing Grid.Column="1" Width="22" Height="22" Margin="12,0" IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </ui:CardExpander.Header>
            <Border Padding="8" Background="Transparent">
            <ListBox Height="500"
                     ItemsSource="{Binding SkyboxChoices}"
                     SelectedItem="{Binding SelectedSkybox, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="5" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="Card" CornerRadius="10" BorderThickness="1" BorderBrush="#445C4B82" Background="#33231B38" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118" />
                                    <RowDefinition Height="38" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" ClipToBounds="True">
                                    <Image x:Name="PreviewImage" Source="{Binding Preview}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Border x:Name="NonePreview" Visibility="Collapsed">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3B2A55" Offset="0" />
                                                <GradientStop Color="#17121F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="58" FontWeight="SemiBold" Foreground="#C4B5FD" />
                                    </Border>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <Border x:Name="SelectedBadge" Grid.RowSpan="2" Width="28" Height="28" Margin="8"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="9"
                                        Background="#E67C3AED" Visibility="Collapsed" Panel.ZIndex="7">
                                    <ui:SymbolIcon Symbol="Checkmark24" Foreground="White" FontSize="17" />
                                </Border>
                                <Rectangle x:Name="SelectionShine" Grid.RowSpan="2" Width="68" HorizontalAlignment="Left"
                                           Panel.ZIndex="5" IsHitTestVisible="False" Opacity="0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#70FFFFFF" Offset="0.5" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform><TranslateTransform X="-80" /></Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsNone}" Value="True">
                                <Setter TargetName="PreviewImage" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="NonePreview" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#E6FFFFFF" />
                                <Setter TargetName="Card" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Card" Property="Background" Value="#33FFFFFF" />
                                <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectionShine" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="-80" To="300" Duration="0:0:0.5">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionShine" Storyboard.TargetProperty="Opacity" Duration="0:0:0.5">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.08" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.41" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </Border>
        </ui:CardExpander>
    </StackPanel>
</ui:UiPage>
