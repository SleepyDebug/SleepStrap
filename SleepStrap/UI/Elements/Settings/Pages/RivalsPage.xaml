<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.RivalsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:SleepStrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:RivalsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="650" d:DesignWidth="800" Title="Rivals" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18" CornerRadius="14" BorderThickness="1" BorderBrush="#668B5CF6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#442D1760" Offset="0" />
                    <GradientStop Color="#662D1B69" Offset="0.55" />
                    <GradientStop Color="#33211A3A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Rivals" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:SymbolIcon Grid.Column="1" Symbol="PlaySettings20" FontSize="34" Foreground="#A78BFA" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource SleepStrapGlassSurfaceBrush}" BorderBrush="{DynamicResource SleepStrapGlassBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,22,0">
                    <TextBlock Text="Screen stretch" FontSize="17" FontWeight="Medium" />
                    <TextBlock Text="Strength" Margin="0,12,0,5" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox Width="230" HorizontalAlignment="Left"
                              ItemsSource="{Binding StretchPresets}"
                              SelectedValuePath="Percent"
                              SelectedValue="{Binding SelectedStretchPercent, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Off" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch IsChecked="{Binding StretchEnabled, Mode=TwoWay}" Margin="0,8" />
                    <TextBlock Text="Stretched" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#B99AFB" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Margin="0,12,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource SleepStrapGlassSurfaceBrush}" BorderBrush="{DynamicResource SleepStrapGlassBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="FPS limit" FontSize="17" FontWeight="Medium" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Width="190"
                          ItemsSource="{Binding FpsPresets}"
                          SelectedValuePath="Limit"
                          SelectedValue="{Binding SelectedFpsLimit, Mode=TwoWay}" />
            </Grid>
        </Border>

        <Border Margin="0,16,0,0" Padding="14,13" CornerRadius="10" Background="#221392F6" BorderBrush="#448B5CF6" BorderThickness="1">
            <TextBlock Text="{Binding StatusText}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

    </StackPanel>
</ui:UiPage>
