<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.RivalsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:SleepStrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:RivalsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="650" d:DesignWidth="800" Title="PC" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18,14,18,12" CornerRadius="14" BorderThickness="0" Background="#C40A0A0C">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="PC" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ui:SymbolIcon Grid.Column="1" Symbol="PlaySettings20" FontSize="34" Foreground="White" Opacity="0.72" />
                </Grid>
                <Border Grid.Row="1" Margin="0,12,0,0" Height="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#00FFFFFF" Offset="0" /><GradientStop Color="#CFFFFFFF" Offset="0.5" /><GradientStop Color="#00FFFFFF" Offset="1" /></LinearGradientBrush></Border.Background></Border>
            </Grid>
        </Border>

        <ui:CardExpander Margin="0,14,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock Text="Screen stretch" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="Horizontal display scaling" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Stretch display" FontSize="14" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Off" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch IsChecked="{Binding StretchEnabled, Mode=TwoWay}" Margin="0,8" />
                    <TextBlock Text="Stretched" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </Grid>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,10,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock Text="FPS limit" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="Choose Roblox's target framerate" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Target framerate" FontSize="14" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" Width="190"
                              ItemsSource="{Binding FpsPresets}"
                              SelectedValuePath="Limit"
                              SelectedValue="{Binding SelectedFpsLimit, Mode=TwoWay}" />
                </Grid>
        </ui:CardExpander>

    </StackPanel>
</ui:UiPage>
