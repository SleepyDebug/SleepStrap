<ui:UiPage x:Class="SleepStrap.UI.Elements.Settings.Pages.TexturesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:SleepStrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:VisualModsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="620" d:DesignWidth="800" Title="Textures" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18" CornerRadius="14" BorderThickness="1" BorderBrush="#668B5CF6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#442D1760" Offset="0" />
                    <GradientStop Color="#662D1B69" Offset="0.55" />
                    <GradientStop Color="#33211A3A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Textures" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:SymbolIcon Grid.Column="1" Symbol="WrenchScrewdriver20" FontSize="34" Foreground="#A78BFA" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Dark textures" FontSize="17" FontWeight="Medium" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Basic" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:ToggleSwitch IsChecked="{Binding DarkTexturesEnabled, Mode=TwoWay}" />
                    <TextBlock Text="Dark" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" Foreground="#B99AFB" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Margin="0,12,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Texture effect" FontSize="17" FontWeight="Medium" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Width="180"
                          ItemsSource="{Binding TextureEffectChoices}"
                          SelectedItem="{Binding SelectedTextureEffect, Mode=TwoWay}" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="12,10" CornerRadius="10" Background="#221392F6" BorderBrush="#448B5CF6" BorderThickness="1">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>
    </StackPanel>
</ui:UiPage>
