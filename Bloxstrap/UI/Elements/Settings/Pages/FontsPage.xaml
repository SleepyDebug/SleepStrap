<ui:UiPage x:Class="Bloxstrap.UI.Elements.Settings.Pages.FontsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:dmodels="clr-namespace:Bloxstrap.UI.ViewModels.Settings"
      mc:Ignorable="d" d:DataContext="{d:DesignInstance dmodels:VisualModsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="620" d:DesignWidth="800" Title="Fonts" Scrollable="True">
    <StackPanel Margin="0,0,14,20">
        <Border Padding="18" CornerRadius="14" BorderThickness="1" BorderBrush="#668B5CF6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#442D1760" Offset="0" />
                    <GradientStop Color="#662D1B69" Offset="0.55" />
                    <GradientStop Color="#33211A3A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Fonts" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:SymbolIcon Grid.Column="1" Symbol="TextFont24" FontSize="34" Foreground="#A78BFA" />
            </Grid>
        </Border>

        <Border Margin="0,14,0,0" Padding="18" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="Roblox font" FontSize="17" FontWeight="Medium" />
                    <TextBlock Text="{Binding FontStatus}" Margin="0,8,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#B99AFB" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ComboBox Width="270" MaxDropDownHeight="330"
                              ItemsSource="{Binding FontChoices}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedFont, Mode=TwoWay}" />
                    <ui:Button Content="Restore Roblox default" Icon="ArrowReset20"
                               Command="{Binding RestoreDefaultFontCommand}"
                               Visibility="{Binding RestoreFontVisibility}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</ui:UiPage>
